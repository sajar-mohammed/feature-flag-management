# ─────────────────────────────────────────────────────────────
#  Environment Variables — copy this file to .env and fill in
#  your own values. Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
# Port the Express server listens on
PORT=5001

# ── Database ─────────────────────────────────────────────────
# MongoDB connection string (Atlas or local)
# Local example:  mongodb://localhost:27017/feature-flags
# Atlas example:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/feature-flags
MONGO_URI=mongodb://localhost:27017/feature-flags

# ── JWT ──────────────────────────────────────────────────────
# Secret used to sign all JWT tokens. Use a long, random string.
JWT_SECRET=your_super_secret_key_change_this_in_production

# ── Super Admin Credentials ───────────────────────────────────
# These are hardcoded credentials for the super-admin account.
# The super-admin is not stored in the database.
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=superadmin123
